PORT=3000
SESSION_SECRET=replace-with-random-string
AUTH_USER=admin
# Generate hash: node -e "import('bcrypt').then(b=>b.default.hash('yourpassword',12).then(console.log))"
AUTH_PASS_HASH=

# App
APP_TIMEZONE=Asia/Omsk
# DB_PATH=./devlog.db

# Telegram backup
BACKUP_TELEGRAM_ENABLED=true
BACKUP_TELEGRAM_AUTORUN=true
BACKUP_TELEGRAM_HOUR=7
BACKUP_TELEGRAM_MINUTE=00
BACKUP_TELEGRAM_KEEP_FILES=14
# Skip Telegram upload if DB snapshot matches last successful send (smart backup)
BACKUP_TELEGRAM_SKIP_IF_UNCHANGED=true
# BACKUP_TELEGRAM_DIR=./backups
TELEGRAM_BOT_TOKEN=
TELEGRAM_BACKUP_CHAT_ID=
# TELEGRAM_BACKUP_THREAD_ID=
# Route Telegram Bot API requests through a SOCKS5 proxy. Use socks5h for proxy-side DNS.
# TELEGRAM_PROXY_URL=socks5h://GERMAN_VPS_IP:1080
# BACKUP_TELEGRAM_REQUEST_TIMEOUT_MS=120000
